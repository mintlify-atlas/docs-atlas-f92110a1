  "keyFeatures": [
    "TLS-fingerprinted HTTP clients with HTTP/2 support",
    "Exponential backoff retry with full jitter",
    "Bounded concurrency primitives via errgroup",
    "File-backed JSON state persistence with locking",
    "PostgreSQL integration with pgx and sqlc",
    "Structured logging with slog and tint",
    "Docker support with hot reload",
    "Interactive setup wizard for feature selection",
    "Environment configuration with validation",
    "Round-robin file rotation utilities"
  ],
  "publicApiSurface": [
    "client.New() - Create TLS-fingerprinted HTTP client",
    "client.Client.Do() - Execute HTTP requests with redirect handling",
    "client.Client.SetCookies() - Manage cookie jar",
    "retry.Do() - Retry function with exponential backoff",
    "retry.WithMaxAttempts() - Configure retry attempts",
    "retry.WithInitialDelay() - Configure initial backoff delay",
    "worker.Run() - Process items with bounded concurrency",
    "worker.Map() - Concurrent map with result collection",
    "state.Open() - Open file-backed state with locking",
    "state.File.Load() - Load persisted state",
    "state.File.Save() - Save state to disk",
    "db.New() - Create PostgreSQL connection pool",
    "db.DB.InTx() - Execute transaction with rollback",
    "db.TryAdvisoryLock() - Acquire Postgres advisory lock",
    "env.Load() - Load and validate environment variables",
    "log.New() - Create structured logger with tint",
    "cycle.New() - Create round-robin file rotator",
    "ptr.To() - Convert value to pointer"
  ]
